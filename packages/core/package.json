{
  "name": "@cassida/core",
  "version": "0.10.0",
  "description": "Cassida runtime — cas() chain builder. In production this is replaced at build time; in dev / for dynamic chains it materializes inline style.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@cassida/compiler": "workspace:*",
    "csstype": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pishio/cassida.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/pishio/cassida/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/pishio/cassida/issues"
  },
  "author": "pishio",
  "keywords": [
    "cassida",
    "css-in-js",
    "compile-time",
    "single-class",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  }
}
