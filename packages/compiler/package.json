{
  "name": "@cassida/compiler",
  "version": "0.11.0",
  "description": "Cassida build-time CSS resolver: registry, canonicalizer, hasher, emitter.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/lightningcss-postprocess.d.ts",
      "import": "./dist/lightningcss-postprocess.js",
      "default": "./dist/lightningcss-postprocess.js"
    },
    "./config.schema.json": "./config.schema.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "config.schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "codegen": "tsx scripts/generate-property-specs.ts",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "csstype": "^3.1.3",
    "stylis": "^4.3.4",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "browserslist": "^4.24.0",
    "lightningcss": "^1.28.1"
  },
  "peerDependenciesMeta": {
    "browserslist": {
      "optional": true
    },
    "lightningcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/stylis": "^4.2.7",
    "browserslist": "^4.24.0",
    "lightningcss": "^1.28.1",
    "mdn-data": "^2.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pishio/cassida.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/pishio/cassida/tree/main/packages/compiler#readme",
  "bugs": {
    "url": "https://github.com/pishio/cassida/issues"
  },
  "author": "pishio",
  "keywords": [
    "cassida",
    "css-in-js",
    "compile-time",
    "single-class",
    "react"
  ],
  "publishConfig": {
    "access": "public"
  }
}
