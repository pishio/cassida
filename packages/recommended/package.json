{
  "name": "@cassida/recommended",
  "version": "0.3.0",
  "description": "Curated bundle of Cassida plugins. `recommended()` returns the CSS- and parser-plugin sets that the maintainers ship as the default-on choice — today: `hoverFix` and `conditionalSpread`. Drop it into `cassida(recommended())` to opt in with one line; pass options to disable individual plugins or supply custom configuration.",
  "license": "MIT",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.test.json",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@cassida/plugin-conditional": "workspace:*",
    "@cassida/plugin-hover-fix": "workspace:*"
  },
  "devDependencies": {
    "@cassida/compiler": "workspace:*",
    "@cassida/parser": "workspace:*",
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pishio/cassida.git",
    "directory": "packages/recommended"
  },
  "homepage": "https://github.com/pishio/cassida/tree/main/packages/recommended#readme",
  "bugs": {
    "url": "https://github.com/pishio/cassida/issues"
  },
  "author": "pishio",
  "keywords": [
    "cassida",
    "css-in-js",
    "compile-time",
    "single-class",
    "react",
    "recommended"
  ],
  "publishConfig": {
    "access": "public"
  }
}
